# SkillOS 环境变量示例

# LLM 配置
# 注意：API key 必须通过命令行参数 --api-key 提供
LLM_API_URL=https://yunwu.ai
LLM_MODEL=gpt-5.4-nano
# LLM_API_KEY 不应该在 .env 文件中，使用命令行参数 --api-key
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30
LLM_RETRY_COUNT=3

# 数据库配置
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_DATABASE=skillos
DB_POSTGRES_USER=postgres
DB_POSTGRES_PASSWORD=your_password_here

DB_NEO4J_URI=bolt://localhost:7687
DB_NEO4J_USER=neo4j
DB_NEO4J_PASSWORD=your_password_here

DB_MONGODB_URI=mongodb://localhost:27017
DB_MONGODB_DATABASE=skillos

DB_REDIS_HOST=localhost
DB_REDIS_PORT=6379
DB_REDIS_DB=0
DB_REDIS_PASSWORD=

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/skillos.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# 应用配置
DEBUG=false
ENVIRONMENT=development
